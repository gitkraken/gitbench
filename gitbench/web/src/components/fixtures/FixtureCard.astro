---
import { Badge } from '@/components/ui/badge';

interface Props {
  fixtureId: string;
  benchmark: string;
  passed: boolean;
  similarity: number;
  difficulty: string;
  tags: string[];
  inputTokens?: number | null;
  outputTokens?: number | null;
}

const { fixtureId, benchmark, passed, similarity, difficulty, tags, inputTokens, outputTokens } = Astro.props;
const passVariant = passed ? 'default' : 'destructive';
const passColor = passed ? 'bg-[var(--color-pass-bg)] text-[var(--color-pass)] border-[var(--color-pass-border)]' : 'bg-[var(--color-fail-bg)] text-[var(--color-fail)] border-[var(--color-fail-border)]';
const tagsStr = tags.join(',');
---

<a
  href={`/fixtures/${encodeURIComponent(benchmark)}/${fixtureId}`}
  class="no-underline card fixture-card p-4 cursor-pointer transition-colors hover:border-[var(--color-border-accent)]"
  data-benchmark={benchmark}
  data-difficulty={difficulty}
  data-tags={tagsStr}
>
  <div class="flex justify-between items-center mb-2">
    <span class="font-mono text-xs text-[var(--color-text-mid)] font-medium">
      {fixtureId}
    </span>
    <Badge variant="outline" className={`font-mono text-[0.6rem] ${passColor}`}>
      {passed ? 'PASS' : 'FAIL'}
    </Badge>
  </div>
  <div class="flex justify-between items-center">
    <span class="font-mono text-[0.62rem] text-[var(--color-text-dim)]">
      {benchmark}
    </span>
    <span class="font-mono text-xs font-semibold text-[var(--color-text)]">
      {similarity}%
    </span>
  </div>
  {difficulty && (
    <div class="mt-1.5">
      <Badge variant="secondary" class="font-mono text-[0.58rem] px-1 py-0">
        {difficulty}
      </Badge>
    </div>
  )}
  {inputTokens != null && outputTokens != null && (
    <div class="mt-1.5 font-mono text-[0.58rem] text-[var(--color-text-dim)] opacity-60">
      {inputTokens}→{outputTokens} tokens
    </div>
  )}
</a>
