---
import { Button } from '@/components/ui/button';
import { Copy } from 'lucide-react';

interface Props {
 text: string;
}

const { text } = Astro.props;
---

<div class="mb-6">
 <div class="flex justify-between items-center mb-2.5">
 <span class="font-mono text-[0.65rem] uppercase tracking-wider text-[var(--color-pass)] opacity-75 " title="The correct answer used for scoring.">
 Expected
 </span>
 <Button
 variant="ghost"
 size="xs"
 class="font-mono text-[0.6rem]"
 data-text={text}
 onclick="navigator.clipboard.writeText(this.getAttribute('data-text') || '')"
 >
 <Copy class="size-3" />
 Copy
 </Button>
 </div>
 <div class="bg-[var(--color-surface)] border border-[var(--color-pass-border)] rounded-xl p-5 font-mono text-xs text-[var(--color-pass)] whitespace-pre-wrap break-words leading-relaxed">
 {text}
 </div>
</div>
