---
import { LayoutDashboard, Cpu, BarChart3, Search, GitCompare, History, BookOpen } from 'lucide-react';

const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}

const links = [
  { href: '/', label: 'Overview', icon: LayoutDashboard },
  { href: '/models', label: 'Models', icon: Cpu },
  { href: '/benchmarks', label: 'Benchmarks', icon: BarChart3 },
  { href: '/explore', label: 'Explore', icon: Search },
  { href: '/compare', label: 'Compare', icon: GitCompare },
  { href: '/history', label: 'History', icon: History },
  { href: '/methodology', label: 'Methodology', icon: BookOpen },
];
---

<aside class="app-sidebar">
  <div class="sidebar-header">
    <div class="sidebar-brand">Git<span class="accent">Bench</span></div>
  </div>
  <nav class="sidebar-nav">
    {links.map(link => (
      <a
        href={link.href}
        class={`sidebar-link${isActive(link.href) ? ' active' : ''}`}
      >
        <link.icon size={18} strokeWidth={2} class="icon" />
        <span>{link.label}</span>
      </a>
    ))}
  </nav>
</aside>
