---
import "@/styles/global.css";
import Sidebar from "@/components/Sidebar.astro";
import { CampaignSelector } from "@/components/CampaignSelector";

interface Props {
  title: string;
}

const { title } = Astro.props;
const generated = new Date().toISOString().split("T")[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title></head
  >: GitBench
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</html>
<body>
  <div class="app-layout">
    <Sidebar />
    <div class="app-main">
      <header class="page-header">
        <h1>{title}</h1>
        <CampaignSelector client:load />
      </header>
      <main class="page-content">
        <slot />
      </main>
      <footer class="app-footer">
        <span>GitBench - Automated Git Task Benchmark</span>
        <span>{generated}</span>
      </footer>
    </div>
  </div>
  <script>
    document
      .querySelectorAll(".sidebar-collapse-toggle, .menu-toggle")
      .forEach(function (input) {
        input.addEventListener("change", function () {
          var checked = this.checked;
          this.setAttribute("aria-expanded", String(checked));
          var nav = this.parentElement.querySelector(".sidebar-nav");
          if (nav) nav.setAttribute("aria-expanded", String(checked));
        });
      });
  </script>
</body>
