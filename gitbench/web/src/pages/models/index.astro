---
import Layout from '../../components/Layout.astro';
import { loadDataSync } from '../../lib/data';
import { Badge } from '@/components/ui/badge';

const data = loadDataSync();
---

<Layout title="Models">
  <div class="grid grid-cols-[repeat(auto-fill,minmax(250px,1fr))] gap-4">
    {data.models.map(m => {
      const summary = data.model_summaries[m.name];
      const passRate = summary ? Math.round(summary.pass_at_k * 1000) / 10 : 0;
      const passCls = summary && summary.pass_at_k >= 0.8 ? 'pass' : summary && summary.pass_at_k < 0.5 ? 'fail' : 'warn';
      const passColor = summary && summary.pass_at_k >= 0.8
        ? 'bg-[var(--color-pass-bg)] text-[var(--color-pass)] border-[var(--color-pass-border)]'
        : summary && summary.pass_at_k < 0.5
          ? 'bg-[var(--color-fail-bg)] text-[var(--color-fail)] border-[var(--color-fail-border)]'
          : 'bg-[var(--color-warn-bg)] text-[var(--color-warn)] border-[var(--color-warn-border)]';
      return (
        <a href={`/models/${encodeURIComponent(m.name)}`} class="no-underline">
          <div class="card p-6 cursor-pointer transition-colors hover:border-[var(--color-border-accent)]">
            <div class="text-lg font-bold mb-1.5 text-[var(--color-text)]">{m.name}</div>
            <div class="flex gap-2 items-center flex-wrap">
              <Badge variant="outline" className={`font-mono text-xs ${passColor}`}>{passRate}%</Badge>
              {m.reasoningLevel && <Badge variant="secondary" class="font-mono text-[0.65rem]">{m.reasoningLevel}</Badge>}
            </div>
            {summary && (
              <div class="font-mono text-[0.65rem] text-[var(--color-text-dim)] mt-2">
                {summary.total_passed} / {summary.total_fixtures} fixtures · {summary.total_runs} run(s)
                {summary.total_cost_usd != null && (
                  <span class="block mt-0.5 opacity-70">
                    Cost: ${summary.total_cost_usd.toFixed(6)} · ~${summary.avg_cost_usd != null ? summary.avg_cost_usd.toFixed(6) : '—'}/fx
                  </span>
                )}
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>
</Layout>
