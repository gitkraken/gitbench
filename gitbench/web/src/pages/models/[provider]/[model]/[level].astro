---
import Layout from '../../../../components/Layout.astro';
import FixtureCard from '../../../../components/fixtures/FixtureCard.astro';
import { loadDataSync } from '../../../../lib/data';
import { modelLevelPath } from '../../../../lib/routes';
import type { GitBenchData, FixtureResult, BaseModelGroup } from '../../../../lib/types';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { GitCompare } from 'lucide-react';
import ProviderIcon from '../../../../components/ProviderIcon.tsx';

export function getStaticPaths() {
  const data = loadDataSync();
  const paths: { params: { provider: string; model: string; level: string }; props: any }[] = [];
  for (const g of data.base_model_groups) {
    for (const l of g.levels) {
      paths.push({
        params: {
          provider: g.provider,
          model: g.baseModel,
          level: l.level || 'default',
        },
        props: {
          provider: g.provider,
          baseModel: g.baseModel,
          level: l.level || 'default',
          modelName: l.modelName,
          group: g,
          data,
        },
      });
    }
  }
  return paths;
}

const { provider, baseModel, level, modelName, group, data } = Astro.props as {
  provider: string;
  baseModel: string;
  level: string;
  modelName: string;
  group: BaseModelGroup;
  data: GitBenchData;
};

const summary = data.model_summaries[modelName];
if (!summary) {
  return new Response('Model not found', { status: 404 });
}

const passRate = Math.round(summary.pass_at_k * 1000) / 10;
const encodedModelName = encodeURIComponent(modelName);
const providerName = provider.charAt(0).toUpperCase() + provider.slice(1);

// Collect all fixture results for this model
const allFixtures: (FixtureResult & { benchmark: string })[] = [];
for (const bench of data.benchmarks) {
  const results = data.fixtures[modelName]?.[bench] || [];
  for (const r of results) {
    allFixtures.push({ ...r, benchmark: bench });
  }
}

// Benchmark list for filter
const benchmarkList = data.benchmarks;

// All unique difficulties / tags
const diffs = new Set<string>();
const allTags = new Set<string>();
for (const fid in data.fixture_index) {
  const fi = data.fixture_index[fid];
  if (fi.difficulty) diffs.add(fi.difficulty);
  for (const t of fi.tags) allTags.add(t);
}

const DIFF_ORDER: Record<string, number> = { trivial: 0, easy: 1, medium: 2, hard: 3, expert: 4 };

const passCls = summary.pass_at_k >= 0.8 ? 'pass' : summary.pass_at_k < 0.5 ? 'fail' : 'warn';
const passColor = summary.pass_at_k >= 0.8
  ? 'bg-[var(--color-pass-bg)] text-[var(--color-pass)] border-[var(--color-pass-border)]'
  : summary.pass_at_k < 0.5
    ? 'bg-[var(--color-fail-bg)] text-[var(--color-fail)] border-[var(--color-fail-border)]'
    : 'bg-[var(--color-warn-bg)] text-[var(--color-warn)] border-[var(--color-warn-border)]';

// Compute total tokens and cost
let totalInputTokens = 0;
let totalOutputTokens = 0;
let totalCost = 0;
let hasCost = false;
for (const bench of data.benchmarks) {
  const results = data.fixtures[modelName]?.[bench] || [];
  for (const r of results) {
    totalInputTokens += (r.input_tokens || 0);
    totalOutputTokens += (r.output_tokens || 0);
    if (r.cost_usd != null) {
      totalCost += r.cost_usd;
      hasCost = true;
    }
  }
}
---

<Layout title={`${providerName} / ${baseModel} / ${level || 'default'}`}>
  <!-- Header with provider icon -->
  <div class="flex items-center gap-3 mb-2">
    <ProviderIcon provider={provider} size={24} client:load />
    <div>
      <div class="text-xs font-mono text-[var(--color-text-dim)]">{providerName} / {baseModel}</div>
      <h1 class="text-xl font-bold text-[var(--color-text)]">{level}</h1>
    </div>
  </div>

  <!-- Reasoning level tab bar -->
  <div class="flex gap-1.5 flex-wrap mb-6">
    {group.levels.map(l => {
      const lvl = l.level || 'default';
      const isCurrent = lvl === level;
      const href = modelLevelPath(provider, baseModel, lvl);
      return (
        <a
          href={href}
          class={`no-underline px-3 py-1.5 rounded-md font-mono text-[0.7rem] transition-colors ${
            isCurrent
              ? 'bg-[var(--color-accent)] text-white'
              : 'bg-[var(--color-card)] text-[var(--color-text-mid)] hover:text-[var(--color-text)]'
          }`}
        >
          {l.level || 'default'}
        </a>
      );
    })}
  </div>

  <!-- Stats + Compare -->
  <div class="flex justify-between items-start flex-wrap gap-4 mb-8">
    <div>
      <div class="flex gap-2 items-center flex-wrap mb-2">
        <Badge variant="outline" className={`font-mono text-xs ${passColor}`}>
          {passRate}%
        </Badge>
        <span class="font-mono text-xs text-[var(--color-text-dim)]">
          {summary.total_passed} / {summary.total_fixtures} fixtures
        </span>
        <span class="font-mono text-[0.68rem] text-[var(--color-text-dim)] opacity-60">
          {summary.total_runs} run(s)
        </span>
      </div>
      <div class="font-mono text-[0.68rem] text-[var(--color-text-dim)] opacity-60 mt-1">
        {(totalInputTokens > 0 || totalOutputTokens > 0) && <span class="mr-3">{totalInputTokens.toLocaleString()} in / {totalOutputTokens.toLocaleString()} out tokens</span>}
        {hasCost && <span>${totalCost.toFixed(8)}</span>}
      </div>
    </div>
    <a href={`/compare?with=${encodedModelName}`}>
      <Button variant="outline" size="sm" class="font-mono text-xs border-[var(--color-border-accent)] text-[var(--color-accent)]">
        <GitCompare class="size-3.5" />
        Compare
      </Button>
    </a>
  </div>

  <section>
    <div class="section-label"><span>Fixture Gallery ({allFixtures.length})</span></div>

    <p class="text-sm text-[var(--color-text-mid)] leading-relaxed max-w-3xl mb-4">
      Each card represents one test fixture — a single Git task this model was asked to complete.
      <span class="has-tooltip" data-tooltip="PASS means the model's output was similar enough to the correct answer (above the scoring threshold, typically 80-90%).

FAIL means the output was too different from what was expected." title="PASS = similar enough to correct answer. FAIL = too different.">PASS/FAIL</span>
      is determined by fuzzy similarity to the expected answer. Use the filters below to find patterns — for example,
      filter to <em>expert</em> difficulty to see where this model struggles most.
      <a href="/methodology#similarity-scoring" class="text-[var(--color-accent)] no-underline text-xs font-mono">Learn more →</a>
    </p>

    <!-- Filter controls -->
    <div id="filter-bar" class="flex gap-1.5 flex-wrap mb-4 items-center">
      <span class="has-tooltip" data-tooltip="Filter fixtures to only show results from a specific benchmark category." title="Filter by benchmark category.">
        <select id="filter-bench" class="brand-select text-xs">
          <option value="">All benchmarks</option>
          {benchmarkList.map(b => <option value={b}>{b}</option>)}
        </select>
      </span>
      <span class="has-tooltip" data-tooltip="Filter by fixture difficulty.

trivial = basic command recall.
easy = single-step operations.
medium = multi-step workflows.
hard = complex scenarios with edge cases.
expert = rare Git operations." title="Filter by difficulty: trivial/easy/medium/hard/expert.">
        <select id="filter-diff" class="brand-select text-xs">
          <option value="">All difficulties</option>
          {Array.from(diffs).sort((a, b) => (DIFF_ORDER[a] ?? 99) - (DIFF_ORDER[b] ?? 99) || a.localeCompare(b)).map(d => <option value={d}>{d}</option>)}
        </select>
      </span>
      <span class="has-tooltip" data-tooltip="Filter fixtures by tag. Tags describe which Git concepts each fixture tests (e.g., 'detached-head', 'restore', 'branching')." title="Filter fixtures by tag (Git concept).">
        <select id="filter-tag" class="brand-select text-xs">
          <option value="">All tags</option>
          {Array.from(allTags).sort().map(t => <option value={t}>{t}</option>)}
        </select>
      </span>
      <button onclick="resetFilters()" class="bg-transparent border border-[var(--color-border)] text-[var(--color-text-dim)] rounded-md px-2.5 py-1.5 font-mono text-[0.65rem] cursor-pointer">
        Reset
      </button>
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(180px,1fr))] gap-3" id="fixture-gallery">
      {allFixtures.map(fx => {
        const fi = data.fixture_index[`${fx.benchmark}/${fx.fixture_id}`];
        const simPct = Math.round(fx.similarity * 1000) / 10;
        return (
          <FixtureCard
            fixtureId={fx.fixture_id}
            benchmark={fx.benchmark || fi?.benchmark || ''}
            passed={fx.passed}
            similarity={simPct}
            difficulty={fi?.difficulty || ''}
            tags={fi?.tags || []}
            inputTokens={fx.input_tokens}
            outputTokens={fx.output_tokens}
          />
        );
      })}
    </div>
  </section>
</Layout>

<script>
  function applyFilters() {
    const bench = document.getElementById('filter-bench')?.value || '';
    const diff = document.getElementById('filter-diff')?.value || '';
    const tag = document.getElementById('filter-tag')?.value || '';
    const cards = document.querySelectorAll('.fixture-card');
    cards.forEach(function(card) {
      const cBench = card.dataset.benchmark || '';
      const cDiff = card.dataset.difficulty || '';
      const cTags = card.dataset.tags || '';
      const show = (!bench || cBench === bench)
        && (!diff || cDiff === diff)
        && (!tag || cTags.split(',').includes(tag));
      card.style.display = show ? '' : 'none';
    });
  }
  function resetFilters() {
    ['filter-bench', 'filter-diff', 'filter-tag'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });
    applyFilters();
  }
  document.getElementById('filter-bench')?.addEventListener('change', applyFilters);
  document.getElementById('filter-diff')?.addEventListener('change', applyFilters);
  document.getElementById('filter-tag')?.addEventListener('change', applyFilters);
</script>
