---
import Layout from "@/components/Layout.astro";
import TimeSeriesChart from "@/components/charts/TimeSeriesChart";
import { CampaignHistory } from "@/components/CampaignHistory";
---

<Layout title="Campaign History">
  <section class="mb-10">
    <div class="section-label"><span>Pass Rate Over Time</span></div>
    <TimeSeriesChart client:load />
  </section>

  <section>
    <div class="info-tip">
      <div class="section-label"><span>Campaign Log</span></div>
      <p class="info-blurb">
        One primary row per evaluation campaign. Δ is shown only when the
        previous campaign has the same configuration hash.
      </p>
    </div>
    <CampaignHistory client:load />
  </section>
</Layout>
