---
import Layout from "@/components/Layout.astro";
import PassRateBarChart from "@/components/charts/PassRateBarChart";
import CostValueChart from "@/components/charts/CostValueChart";
import RuntimeBarChart from "@/components/charts/RuntimeBarChart";
import TokenUsageChart from "@/components/charts/TokenUsageChart";
import QuadrantComparisonChart from "@/components/charts/QuadrantComparisonChart";
import ModelSelector from "@/components/charts/ModelSelector";
import BenchmarkHeatmap from "@/components/charts/BenchmarkHeatmap";
---

<Layout title="Overview">
  <section class="mb-8">
    <div class="card">
      <div class="section-label"><span>About</span></div>
      <div
        class="space-y-3 text-sm text-(--color-text-mid) leading-relaxed max-w-3xl"
      >
        <p>
          <strong class="text-(--color-text)"
            >Every AI model claims it can code. Git is a different beast.</strong
          >
          It's not about knowing the answer. It's about knowing the exact
          command. GitBench puts that to the test.
        </p>
        <p>
          204 fixtures. Each one asks a model to write a git command. The
          output gets fuzzy-matched against the correct answer. Every test runs
          in an isolated repo. Deterministic. Reproducible. No luck, no vibes.
        </p>
        <p>
          Picking an AI coding assistant? Fine-tuning your own model? Just
          curious how the latest LLMs handle Git? This dashboard gives you
          transparent, reproducible data. Not marketing.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="section-label">
      <span>Model Summary</span>
    </div>
    <PassRateBarChart client:load />
  </section>

  <section class="mt-10">
    <div class="info-tip">
      <div class="section-label">
        <span>Quadrant Comparison</span>
      </div>
      <p class="info-blurb">
        Pick two criteria. The shaded quadrant is the optimal direction.
        For example, lower cost with higher pass rate.
      </p>
    </div>
    <QuadrantComparisonChart client:load />
  </section>

  <section class="mt-10">
    <div class="section-label">
      <span>Cost per Full Run</span>
    </div>
    <CostValueChart client:load />
  </section>

  <section class="mt-10">
    <div class="info-tip">
      <div class="section-label">
        <span>Runtime (Wall Clock)</span>
      </div>
      <p class="info-blurb">
        Wall-clock time for all 204 fixtures. Includes API latency and rate
        limiting. Not a pure model speed benchmark.
      </p>
    </div>
    <RuntimeBarChart client:load />
  </section>

  <section class="mt-10">
    <div class="section-label">
      <span>Token Usage</span>
    </div>
    <TokenUsageChart client:load />
  </section>

  <section class="mt-10">
    <div class="info-tip">
      <div class="section-label">
        <span>Benchmark Matrix</span>
      </div>
      <p class="info-blurb">
        The deep dive. Rows are Git task categories, columns are models. Green
        cells show where a model excels. Red cells reveal weaknesses. Look for
        models that crush basics but fall apart on rebase or bisect.
      </p>
    </div>
    <BenchmarkHeatmap client:load />
  </section>
</Layout>
