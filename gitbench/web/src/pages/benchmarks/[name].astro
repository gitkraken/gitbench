---
import Layout from '../../components/Layout.astro';
import PassRateBarChart from '../../components/charts/PassRateBarChart';
import { loadDataSync } from '../../lib/data';
import type { GitBenchData } from '../../lib/types';
import { Badge } from '@/components/ui/badge';

export function getStaticPaths() {
 const data = loadDataSync();
 return data.benchmarks.map(b => ({
 params: { name: b },
 props: { benchName: b, data },
 }));
}

const { benchName, data } = Astro.props as { benchName: string; data: GitBenchData };

// Collect all fixtures in this benchmark
const fixtureKeys = Object.keys(data.fixture_index)
 .filter(k => data.fixture_index[k].benchmark === benchName);

// Tag breakdown
const tagCounts: Record<string, number> = {};
for (const fid of fixtureKeys) {
 const fi = data.fixture_index[fid];
 for (const t of fi?.tags || []) {
 tagCounts[t] = (tagCounts[t] || 0) + 1;
 }
}
---

<Layout title={benchName}>
 <div class="card mb-8">
 <div class="font-mono text-[0.68rem] text-[var(--color-text-dim)] mb-1">Benchmark</div>
 <div class="text-lg font-semibold">{benchName}</div>
 <div class="font-mono text-[0.7rem] text-[var(--color-text-dim)] mt-2">
 {fixtureKeys.length} fixtures
 </div>
 </div>

 <section class="mb-10">
 <div class="section-label"><span>Model Leaderboard</span></div>
 <p class="text-sm text-[var(--color-text-mid)] leading-relaxed max-w-3xl mb-4">
 Models ranked by pass rate on <strong class="text-[var(--color-text)]">{benchName}</strong> specifically.
 A model that dominates overall might rank lower here — this reveals each model's true strengths and weaknesses per skill.
 <a href="/compare" class="text-[var(--color-accent)] no-underline text-xs font-mono">Compare models side-by-side →</a>
 </p>
 <PassRateBarChart client:load />
 </section>

 {
 Object.keys(tagCounts).length > 0 && (
 <section class="mb-10">
 <div class="section-label"><span>Tags</span></div>
 <div class="flex gap-1.5 flex-wrap">
 {Object.entries(tagCounts).sort(([,a], [,b]) => b - a).map(([tag, count]) => (
 <a href={`/explore?tag=${encodeURIComponent(tag)}`} class="no-underline">
 <Badge variant="secondary" class="font-mono text-[0.65rem] cursor-pointer">{tag} ({count})</Badge>
 </a>
 ))}
 </div>
 </section>
 )
 }

 <section>
 <div class="section-label"><span>Per-Fixture Comparison</span></div>
 <p class="text-sm text-[var(--color-text-mid)] leading-relaxed max-w-3xl mb-4">
 Each row is one test fixture, each column is one model. Percentages show how similar the model's output was to the correct answer.
 <span title="Green = passed, red = failed. Click fixture ID for full details.">Green cells passed, red cells failed.</span>
 Click any fixture to drill into the full prompt and all model responses.
 </p>
 <div class="card overflow-x-auto p-5">
 <table class="data-table">
 <thead>
 <tr>
 <th><span title="Click to see the full fixture prompt and all model responses.">Fixture</span></th>
 <th><span title="Fixture complexity: trivial/easy/medium/hard/expert.">Difficulty</span></th>
 {data.models.map(m => <th>{m.name}</th>)}
 </tr>
 </thead>
 <tbody>
 {fixtureKeys.map(fid => {
 const fi = data.fixture_index[fid];
 const shortId = fi.id;
 return (
 <tr>
 <td>
 <a href={`/fixtures/${encodeURIComponent(benchName)}/${shortId}`} class="inline-flex items-center px-2 py-0.5 rounded font-mono text-xs bg-white/5 text-[var(--color-text-mid)] border border-[var(--color-border)] no-underline">
 {shortId}
 </a>
 </td>
 <td class="font-mono text-[0.68rem] text-[var(--color-text-dim)]">
 <span title="Fixture complexity: {fi?.difficulty || 'unknown'}.">{fi?.difficulty || '—'}</span>
 </td>
 {data.models.map(m => {
 const results = data.fixtures[m.name]?.[benchName] || [];
 const fr = results.find(r => r.fixture_id === fid);
 if (!fr) {
 return <td class="text-[var(--color-text-dim)] opacity-40 font-mono text-xs">—</td>;
 }
 const sim = Math.round(fr.similarity * 1000) / 10;
 const isPass = fr.passed;
 const color = isPass
 ? 'bg-[var(--color-pass-bg)] text-[var(--color-pass)] border-[var(--color-pass-border)]'
 : 'bg-[var(--color-fail-bg)] text-[var(--color-fail)] border-[var(--color-fail-border)]';
 return (
 <td>
 <Badge variant="outline" className={`font-mono text-[0.62rem] ${color}`}>{sim}%</Badge>
 </td>
 );
 })}
 </tr>
 );
 })}
 </tbody>
 </table>
 </div>
 </section>
</Layout>
