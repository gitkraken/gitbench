---
import Layout from "@/components/Layout.astro";
import PassRateBarChart from "@/components/charts/PassRateBarChart";
import { loadDataSync } from "@/lib/data";
import type { GitBenchData } from "@/lib/types";
import { Badge } from "@/components/ui/badge";

export function getStaticPaths() {
  const data = loadDataSync();
  return data.benchmarks.map((b) => ({
    params: { name: b },
    props: { benchName: b, data },
  }));
}

const { benchName, data } = Astro.props as {
  benchName: string;
  data: GitBenchData;
};

// Collect all fixtures in this benchmark
const fixtureKeys = Object.keys(data.fixture_index).filter(
  (k) => data.fixture_index[k].benchmark === benchName,
);

// Tag breakdown
const tagCounts: Record<string, number> = {};
for (const fid of fixtureKeys) {
  const fi = data.fixture_index[fid];
  for (const t of fi?.tags || []) {
    tagCounts[t] = (tagCounts[t] || 0) + 1;
  }
}
---

<Layout title={benchName}>
  <div class="card mb-8">
    <div class="font-mono text-[0.68rem] text-(--color-text-dim) mb-1">
      Benchmark
    </div>
    <div class="text-lg font-semibold">{benchName}</div>
    <div class="font-mono text-[0.7rem] text-(--color-text-dim) mt-2">
      {fixtureKeys.length} fixtures
    </div>
  </div>

  <section class="mb-10">
    <div class="info-tip">
      <div class="section-label"><span>Model Leaderboard</span></div>
      <p class="info-blurb">
        Models ranked by pass rate on <strong class="text-(--color-text)"
          >{benchName}</strong
        >. A model that dominates overall might rank lower here. That's
        the point.
      </p>
    </div>
    <PassRateBarChart client:load />
  </section>

  {
    Object.keys(tagCounts).length > 0 && (
      <section class="mb-10">
        <div class="section-label">
          <span>Tags</span>
        </div>
        <div class="flex gap-1.5 flex-wrap">
          {Object.entries(tagCounts)
            .sort(([, a], [, b]) => b - a)
            .map(([tag, count]) => (
              <a
                href={`/explore?tag=${encodeURIComponent(tag)}`}
                class="no-underline"
              >
                <Badge
                  variant="secondary"
                  class="font-mono text-[0.65rem] cursor-pointer"
                >
                  {tag} ({count})
                </Badge>
              </a>
            ))}
        </div>
      </section>
    )
  }

  <section>
    <div class="section-label"><span>Per-Fixture Comparison</span></div>
    <div class="card overflow-x-auto p-5">
      <table class="data-table">
        <thead>
          <tr>
            <th>Fixture</th>
            <th>Difficulty</th>
            {data.models.map((m) => <th>{m.name}</th>)}
          </tr>
        </thead>
        <tbody>
          {
            fixtureKeys.map((fid) => {
              const fi = data.fixture_index[fid];
              const shortId = fi.id;
              return (
                <tr>
                  <td>
                    <a
                      href={`/fixtures/${encodeURIComponent(benchName)}/${shortId}`}
                      class="inline-flex items-center px-2 py-0.5 rounded font-mono text-xs bg-white/5 text-(--color-text-mid) border border-border no-underline"
                    >
                      {shortId}
                    </a>
                  </td>
                  <td class="font-mono text-[0.68rem] text-(--color-text-dim)">
                    {fi?.difficulty || "—"}
                  </td>
                  {data.models.map((m) => {
                    const results = data.fixtures[m.name]?.[benchName] || [];
                    const fr = results.find((r) => r.fixture_id === fid);
                    if (!fr) {
                      return (
                        <td class="text-(--color-text-dim) opacity-40 font-mono text-xs">
                          —
                        </td>
                      );
                    }
                    const sim = Math.round(fr.similarity * 1000) / 10;
                    const isPass = fr.passed;
                    const color = isPass
                      ? "bg-pass-bg text-pass border-pass-border"
                      : "bg-fail-bg text-fail border-(--color-fail-border)";
                    return (
                      <td>
                        <Badge
                          variant="outline"
                          className={`font-mono text-[0.62rem] ${color}`}
                        >
                          {sim}%
                        </Badge>
                      </td>
                    );
                  })}
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </section>
</Layout>
