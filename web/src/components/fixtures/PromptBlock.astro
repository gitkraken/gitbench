---
import { buttonVariants } from "@/components/ui/button";
import { Copy } from "lucide-react";

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="mb-6">
  <div class="flex justify-between items-center mb-2.5">
    <span
      class="font-mono text-[0.65rem] uppercase tracking-wider text-accent opacity-75"
      title="The exact text sent to the model."
    >
      Prompt
    </span>
    <button
      type="button"
      class={buttonVariants({
        variant: "ghost",
        size: "xs",
        className: "font-mono text-[0.6rem]",
      })}
      data-text={text}
      onclick="navigator.clipboard.writeText(this.getAttribute('data-text') || '')"
    >
      <Copy className="size-3" />
      Copy
    </button>
  </div>
  <div
    class="bg-(--color-surface) border border-border rounded-xl p-5 font-mono text-xs text-(--color-text-mid) whitespace-pre-wrap wrap-break-word leading-relaxed max-h-[500px] overflow-y-auto"
  >
    {text}
  </div>
</div>
