---
import { buttonVariants } from "@/components/ui/button";
import { Copy } from "lucide-react";

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="mb-6">
  <div class="flex justify-between items-center mb-2.5">
    <span
      class="font-mono text-[0.65rem] uppercase tracking-wider text-pass opacity-75"
      title="The correct answer used for scoring."
    >
      Expected
    </span>
    <button
      type="button"
      class={buttonVariants({
        variant: "ghost",
        size: "xs",
        className: "font-mono text-[0.6rem]",
      })}
      data-text={text}
      onclick="navigator.clipboard.writeText(this.getAttribute('data-text') || '')"
    >
      <Copy className="size-3" />
      Copy
    </button>
  </div>
  <div
    class="bg-(--color-surface) border border-pass-border rounded-xl p-5 font-mono text-xs text-pass whitespace-pre-wrap wrap-break-word leading-relaxed"
  >
    {text}
  </div>
</div>
