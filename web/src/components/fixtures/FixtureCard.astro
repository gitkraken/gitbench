---
import { Check, X } from "lucide-react";
import { fixturePath } from "@/lib/routes";
import {
  REASONING_WITHIN_OUTPUT_LABEL,
  TOTAL_OUTPUT_LABEL,
} from "@/lib/token-usage";

interface Props {
  fixtureId: string;
  benchmark: string;
  passed: boolean;
  similarity: number;
  difficulty: string;
  tags: string[];
  inputTokens?: number | null;
  outputTokens?: number | null;
  reasoningTokens?: number | null;
  reasoningLevel?: string | null;
  modelName?: string | null;
  outputMode?: string | null;
}

const {
  fixtureId,
  benchmark,
  passed,
  similarity,
  difficulty,
  tags,
  inputTokens,
  outputTokens,
  reasoningTokens,
  reasoningLevel,
  modelName,
  outputMode,
} = Astro.props;
const passColor = passed
  ? "text-pass bg-pass-bg border-pass-border"
  : "text-fail bg-fail-bg border-(--color-fail-border)";
const tagsStr = tags.join(",");
const hasTokenData = inputTokens != null || outputTokens != null;
const hasReasoningData = reasoningLevel != null && reasoningLevel !== "";
const inputTokenLabel =
  inputTokens != null ? inputTokens.toLocaleString() : "n/a";
const outputTokenLabel =
  outputTokens != null ? outputTokens.toLocaleString() : "n/a";
const reasoningTokenLabel =
  reasoningTokens != null ? reasoningTokens.toLocaleString() : "N/A";
const href = fixturePath(
  benchmark,
  fixtureId,
  modelName ? { modelName, outputMode } : undefined,
);
---

<a
  href={href}
  class="no-underline card fixture-card flex min-h-[132px] flex-col justify-between p-4 cursor-pointer transition-colors hover:border-(--color-border-accent)"
  data-benchmark={benchmark}
  data-difficulty={difficulty}
  data-tags={tagsStr}
>
  <div class="flex items-start justify-between gap-3">
    <span class="shrink-0 font-mono text-[0.62rem] text-(--color-text-dim)">
      {benchmark}
    </span>
    <span
      class="min-w-0 truncate font-mono text-xs font-medium text-(--color-text-mid)"
    >
      {fixtureId}
    </span>
  </div>

  <div class="flex items-center justify-center gap-2 py-4">
    <span
      class="font-mono text-lg font-semibold tabular-nums text-(--color-text)"
    >
      {similarity}%
    </span>
    <span
      class={`inline-flex size-7 items-center justify-center rounded-full border ${passColor}`}
    >
      {
        passed ? (
          <Check className="size-4" aria-hidden="true" />
        ) : (
          <X className="size-4" aria-hidden="true" />
        )
      }
      <span class="sr-only">{passed ? "Passed" : "Failed"}</span>
    </span>
  </div>

  {
    hasTokenData && (
      <div>
        <div class="mb-2 flex items-center gap-2">
          <span class="font-mono text-[0.58rem] uppercase tracking-normal text-(--color-text-dim)">
            Tokens
          </span>
          <span class="h-px flex-1 bg-border" aria-hidden="true" />
        </div>
        <div
          class={`grid ${hasReasoningData ? "grid-cols-3" : "grid-cols-2"} gap-3`}
        >
          <div>
            <div class="font-mono text-xs font-semibold tabular-nums text-(--color-text)">
              {inputTokenLabel}
            </div>
            <div class="mt-1 font-mono text-[0.58rem] uppercase tracking-normal text-(--color-text-dim)">
              Input
            </div>
          </div>
          <div class="text-right">
            <div class="font-mono text-xs font-semibold tabular-nums text-(--color-text)">
              {outputTokenLabel}
            </div>
            <div class="mt-1 font-mono text-[0.58rem] uppercase tracking-normal text-(--color-text-dim)">
              {hasReasoningData ? TOTAL_OUTPUT_LABEL : "Output"}
            </div>
          </div>
          {hasReasoningData && (
            <div class="text-right">
              <div class="font-mono text-xs font-semibold tabular-nums text-(--color-text-dim)">
                {reasoningTokenLabel}
              </div>
              <div class="mt-1 font-mono text-[0.58rem] uppercase tracking-normal text-(--color-text-dim) opacity-60">
                {REASONING_WITHIN_OUTPUT_LABEL}
              </div>
            </div>
          )}
        </div>
      </div>
    )
  }
</a>
