---
import {
  LayoutDashboard,
  Cpu,
  BarChart3,
  Search,
  GitCompare,
  History,
  BookOpen,
  ChevronLeft,
  ChevronRight,
} from "lucide-react";
import { loadDataSync } from "@/lib/data";
// import { hasRepeatModelRuns } from "@/lib/history";

const currentPath = Astro.url.pathname;
const data = loadDataSync();
const showHistory = false;
// History is hidden for now
// const showHistory = hasRepeatModelRuns(data.runs_meta);

function isActive(path: string) {
  if (path === "/") return currentPath === "/";
  return currentPath.startsWith(path);
}

const links = [
  { href: "/", label: "Overview", icon: LayoutDashboard },
  { href: "/models", label: "Models", icon: Cpu },
  { href: "/benchmarks", label: "Benchmarks", icon: BarChart3 },
  { href: "/explore", label: "Explore", icon: Search },
  { href: "/compare", label: "Compare", icon: GitCompare },
  ...(showHistory
    ? [{ href: "/history", label: "History", icon: History }]
    : []),
  { href: "/methodology", label: "Methodology", icon: BookOpen },
] as const;
---

<aside class="app-sidebar">
  <input
    type="checkbox"
    id="sidebar-collapse-toggle"
    class="sidebar-collapse-toggle"
  />
  <input type="checkbox" id="menu-toggle" class="menu-toggle" />
  <div class="sidebar-header">
    <div class="sidebar-brand-lockup">
      <img
        class="sidebar-logo"
        src="/gitkraken-icon.svg"
        alt=""
        width="44"
        aria-hidden="true"
      />
      <div class="sidebar-product" aria-label="GitBench by GitKraken">
        <span class="sidebar-product-title">GitBench</span>
        <span class="sidebar-product-subtitle">by GitKraken</span>
      </div>
    </div>
    <label for="menu-toggle" class="menu-btn" aria-label="Toggle menu">
      <span class="menu-btn-bar"></span>
      <span class="menu-btn-bar"></span>
      <span class="menu-btn-bar"></span>
    </label>
  </div>
  <nav class="sidebar-nav">
    {
      links.map((link) => (
        <a
          href={link.href}
          class={`sidebar-link${isActive(link.href) ? " active" : ""}`}
        >
          <link.icon size={18} strokeWidth={2} className="icon" />
          <span>{link.label}</span>
        </a>
      ))
    }
  </nav>
  <label
    for="sidebar-collapse-toggle"
    class="sidebar-collapse-btn"
    title="Toggle sidebar"
    aria-label="Toggle sidebar"
  >
    <span class="collapse-icon-expanded"><ChevronLeft size={16} /></span>
    <span class="collapse-icon-collapsed"><ChevronRight size={16} /></span>
  </label>
</aside>
