---
import Layout from "@/components/Layout.astro";
import PassRateBarChart from "@/components/charts/PassRateBarChart";
import CostValueChart from "@/components/charts/CostValueChart";
import RuntimeBarChart from "@/components/charts/RuntimeBarChart";
import TokenUsageChart from "@/components/charts/TokenUsageChart";
import QuadrantComparisonChart from "@/components/charts/QuadrantComparisonChart";
import ModelSelector from "@/components/charts/ModelSelector";
import BenchmarkHeatmap from "@/components/charts/BenchmarkHeatmap";
import EmailCta from "@/components/EmailCta";
import { getReportStore } from "@/lib/node-sqlite-report-store";
import { chartData } from "@/lib/chart-data";

const store = getReportStore();
const defaultCampaign = store.getDefaultCampaign();
const passRateData = {
  ...chartData(
    "pass-rate",
    store.getSummary({ campaign_id: defaultCampaign?.campaign_id ?? null }),
  ),
  campaign_id: defaultCampaign?.campaign_id ?? null,
  campaign_metadata: defaultCampaign ?? null,
};
---

<Layout
  title="Overview"
  description="GitBench ranks AI models on deterministic Git tasks, with pass rates, cost, runtime, token usage, and fixture-level evidence."
  image="/og/overview.png"
>
  <section class="mb-8">
    <div class="card">
      <div class="section-label"><span>About</span></div>
      <div
        class="space-y-3 flex flex-col lg:flex-row lg:space-x-8 text-sm text-(--color-text-mid) leading-relaxed"
      >
        <div>
          <strong class="text-(--color-text)">
            Every AI model claims it can code. Git is a different beast.
          </strong>

          <p>
            GitBench is comprised of 204 fixtures across 12 benchmark suites.
            Every test runs in an isolated git worktree. Fixture inputs are
            deterministic within an evaluation run.
          </p>
        </div>
        <div>
          <strong class="text-(--color-text)">
            Why is GitBench valuable?
          </strong>
          <p>
            Picking an AI coding assistant? Fine-tuning your own model? Just
            curious how the latest LLMs handle Git? This dashboard gives you
            transparent, reproducible data.
          </p>
        </div>
      </div>
    </div>

    <section class="my-8">
      <EmailCta client:load />
    </section>

    <section>
      <div class="info-tip">
        <div class="section-label">
          <span>Model Summary</span>
        </div>
        <p class="info-blurb">
          The aggregated and averaged results for each model across all
          benchmarks and effort levels. The whiskers show the range of values
          from the effort levels to give you an idea of the range of results.
        </p>
      </div>
      <PassRateBarChart client:load initialData={passRateData} />
    </section>

    <section class="mt-10">
      <div class="info-tip">
        <div class="section-label">
          <span>Quadrant Comparison</span>
        </div>
        <p class="info-blurb">
          Pick two criteria. The shaded quadrant is the optimal direction. For
          example, lower cost with higher pass rate.
        </p>
      </div>
      <QuadrantComparisonChart client:visible />
    </section>

    <section class="mt-10">
      <div class="info-tip">
        <div class="section-label">
          <span>Cost per Full Run</span>
        </div>
        <p class="info-blurb">
          Input and Output tokens as well as Reasoning tokens for models that
          support it.
        </p>
      </div>
      <CostValueChart client:visible />
    </section>

    <section class="mt-10">
      <div class="info-tip">
        <div class="section-label">
          <span>API Time</span>
        </div>
        <p class="info-blurb">
          API call latency across successful fixture calls. It excludes fixture
          setup, scoring, and cleanup.
        </p>
      </div>
      <RuntimeBarChart client:load />
    </section>

    <section class="mt-10">
      <div class="info-tip">
        <div class="section-label">
          <span>Token Usage</span>
        </div>
        <p class="info-blurb">
          Input and Output tokens as well as Reasoning tokens for models that
          support it.
        </p>
      </div>
      <TokenUsageChart client:visible />
    </section>

    <section class="mt-10">
      <div class="info-tip">
        <div class="section-label">
          <span>Benchmark Matrix</span>
        </div>
        <p class="info-blurb">
          Rows are Git task categories, columns are models. Green cells show
          where a model excels. Red cells reveal weaknesses.
        </p>
      </div>
      <BenchmarkHeatmap client:visible />
    </section>
  </section>
</Layout>
