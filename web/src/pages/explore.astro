---
import Layout from "@/components/Layout.astro";
import { loadDataSync } from "@/lib/data";
import type { GitBenchData } from "@/lib/types";
import { Badge } from "@/components/ui/badge";
import { DIFFICULTY_ORDER } from "@/lib/sort-orders";

const data = loadDataSync();

// Build tag list with counts
const tagCounts: Record<string, number> = {};
const allDiffs = new Set<string>();
for (const fid in data.fixture_index) {
  const fi = data.fixture_index[fid];
  if (fi.difficulty) allDiffs.add(fi.difficulty);
  for (const t of fi.tags) {
    tagCounts[t] = (tagCounts[t] || 0) + 1;
  }
}

const sortedTags = Object.entries(tagCounts).sort(([, a], [, b]) => b - a);
const diffsSorted = Array.from(allDiffs).sort(
  (a, b) => (DIFFICULTY_ORDER[a] ?? 99) - (DIFFICULTY_ORDER[b] ?? 99) || a.localeCompare(b),
);
const maxCount = Math.max(...sortedTags.map((t) => t[1]));

// Build fixture list for client-side filtering
const allFixtures = Object.values(data.fixture_index);
---

<Layout
  title="Explore"
  description="Filter GitBench fixtures by tag, difficulty, and benchmark, then inspect prompts, expected answers, and model attempts."
  image="/og/explore.png"
>
  <div class="info-tip">
    <div class="section-label"><span>About</span></div>
    <p class="info-blurb">
      204 test cases. Filter by tag, difficulty, or benchmark.
      Click any fixture card to see the full prompt and all model responses.
    </p>
  </div>
  <div class="mb-8">
    <div class="section-label"><span>Explore Tags</span></div>

    <!-- Search input -->
    <input
      type="search"
      id="tag-search"
      placeholder="Filter tags & fixtures..."
      class="w-full bg-(--color-card) text-(--color-text) border border-border rounded-md px-3 py-2 font-mono text-xs placeholder:text-(--color-text-dim) focus:outline-none focus:border-(--color-border-accent) mb-3"
    />

    <!-- Popular tags row -->
    <div class="flex gap-1.5 flex-wrap items-center mb-2" id="popular-tags">
      {
        sortedTags.slice(0, 10).map(([tag, count]) => (
          <a
            href={`?tag=${encodeURIComponent(tag)}`}
            class="tag-pill inline-flex cursor-pointer no-underline"
            data-tag={tag}
            title={`Filter fixtures by tag: ${tag} (${count} fixtures)`}
          >
            {tag}
            <span class="opacity-40 ml-1 text-[0.6rem]">{count}</span>
          </a>
        ))
      }
    </div>

    <!-- Show all toggle + full tag list -->
    <button
      id="tag-toggle"
      class="font-mono text-[0.65rem] text-accent cursor-pointer bg-transparent border-none p-0 mb-1"
    >
      Show all {sortedTags.length} tags ▾
    </button>
    <div class="flex gap-1.5 flex-wrap mb-2 hidden" id="all-tags">
      {
        sortedTags.slice(10).map(([tag, count]) => (
          <a
            href={`?tag=${encodeURIComponent(tag)}`}
            class="tag-pill inline-flex cursor-pointer no-underline"
            data-tag={tag}
            title={`Filter fixtures by tag: ${tag} (${count} fixtures)`}
          >
            {tag}
            <span class="opacity-40 ml-1 text-[0.6rem]">{count}</span>
          </a>
        ))
      }
    </div>
  </div>

  <div class="mb-8">
    <div class="section-label"><span>Filters</span></div>
    <div class="flex gap-2 flex-wrap items-center" id="filter-controls">
      <span>
        <select id="explore-tag" class="brand-select text-xs">
          <option value="">Any tag</option>
          {sortedTags.map(([tag]) => <option value={tag}>{tag}</option>)}
        </select>
      </span>
      <span>
        <select id="explore-diff" class="brand-select text-xs">
          <option value="">Any difficulty</option>
          {diffsSorted.map((d) => <option value={d}>{d}</option>)}
        </select>
      </span>
      <span>
        <select id="explore-bench" class="brand-select text-xs">
          <option value="">Any benchmark</option>
          {data.benchmarks.map((b) => <option value={b}>{b}</option>)}
        </select>
      </span>
      <button
        onclick="resetExploreFilters()"
        class="bg-transparent border border-border text-(--color-text-dim) rounded-md px-2.5 py-1.5 font-mono text-[0.65rem] cursor-pointer"
      >
        Reset
      </button>
    </div>
  </div>

  <section>
    <div class="section-label">
      <span>Results</span>
      <span
        id="result-count"
        class="font-mono text-xs text-(--color-text-dim)"></span>
    </div>
    <div class="flex flex-col gap-2.5" id="explore-results">
      {
        allFixtures.map((fi) => (
          <div
            class="card explore-result p-4 flex justify-between items-center flex-wrap gap-3 cursor-pointer"
            data-tags={fi.tags.join(",")}
            data-diff={fi.difficulty}
            data-bench={fi.benchmark}
            onclick={`window.location='/fixtures/${encodeURIComponent(fi.benchmark)}/${fi.id}'`}
          >
            <div class="flex gap-2 items-center flex-wrap">
              <span class="font-mono text-xs text-(--color-text-mid) font-medium">
                {fi.id}
              </span>
              <Badge variant="secondary" className="font-mono text-[0.6rem]">
                {fi.benchmark}
              </Badge>
              {fi.difficulty && (
                <Badge
                  variant="outline"
                  className="font-mono text-[0.55rem] opacity-50 border-pass-border text-pass"
                >
                  {fi.difficulty}
                </Badge>
              )}
            </div>
            <div class="flex gap-1 flex-wrap">
              {fi.tags.slice(0, 3).map((t) => (
                <Badge
                  variant="secondary"
                  className="font-mono text-[0.55rem] px-1 py-0"
                >
                  {t}
                </Badge>
              ))}
              {fi.tags.length > 3 && (
                <span class="font-mono text-[0.6rem] text-(--color-text-dim)">
                  +{fi.tags.length - 3}
                </span>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  function applyExploreFilters() {
    const tag =
      (document.getElementById("explore-tag") as HTMLSelectElement)?.value ||
      "";
    const diff =
      (document.getElementById("explore-diff") as HTMLSelectElement)?.value ||
      "";
    const bench =
      (document.getElementById("explore-bench") as HTMLSelectElement)?.value ||
      "";
    const search =
      (document.getElementById("tag-search") as HTMLInputElement)?.value || "";
    const results = document.querySelectorAll(".explore-result");
    let visible = 0;
    results.forEach((el: any) => {
      const tags = (el.dataset.tags || "").split(",");
      const d = el.dataset.diff || "";
      const b = el.dataset.bench || "";
      const show =
        (!tag || tags.includes(tag)) &&
        (!diff || d === diff) &&
        (!bench || b === bench);
      el.style.display = show ? "" : "none";
      if (show) visible++;
    });
    const countEl = document.getElementById("result-count");
    if (countEl)
      countEl.textContent = `(${visible} fixture${visible !== 1 ? "s" : ""})`;
  }
  function resetExploreFilters() {
    ["explore-tag", "explore-diff", "explore-bench"].forEach((id) => {
      const el = document.getElementById(id) as HTMLSelectElement;
      if (el) el.value = "";
    });
    const si = document.getElementById("tag-search") as HTMLInputElement;
    if (si) si.value = "";
    applyExploreFilters();
  }

  // Filter selects
  document
    .getElementById("explore-tag")
    ?.addEventListener("change", applyExploreFilters);
  document
    .getElementById("explore-diff")
    ?.addEventListener("change", applyExploreFilters);
  document
    .getElementById("explore-bench")
    ?.addEventListener("change", applyExploreFilters);

  // Tag search filtering
  const tagSearch = document.getElementById("tag-search") as HTMLInputElement;
  if (tagSearch) {
    tagSearch.addEventListener("input", () => {
      const q = tagSearch.value.toLowerCase();
      document.querySelectorAll(".tag-pill").forEach((el: any) => {
        const t = (el.dataset.tag || "").toLowerCase();
        el.style.display = !q || t.includes(q) ? "" : "none";
      });
      applyExploreFilters();
    });
  }

  // Tag pill clicks: set explore-tag select and apply filters
  document.querySelectorAll(".tag-pill").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      const tag = (el as HTMLElement).dataset.tag || "";
      const select = document.getElementById(
        "explore-tag",
      ) as HTMLSelectElement;
      if (select) {
        select.value = tag;
      }
      applyExploreFilters();
    });
  });

  // Show all tags toggle
  const toggleBtn = document.getElementById("tag-toggle");
  const allTags = document.getElementById("all-tags");
  if (toggleBtn && allTags) {
    toggleBtn.addEventListener("click", () => {
      const hidden = allTags.classList.contains("hidden");
      allTags.classList.toggle("hidden");
      toggleBtn.textContent = hidden
        ? "Show fewer ▴"
        : "Show all {sortedTags.length} tags ▾";
    });
  }

  applyExploreFilters();

  // Handle ?tag= query param
  const params = new URLSearchParams(window.location.search);
  const initialTag = params.get("tag");
  if (initialTag) {
    const select = document.getElementById("explore-tag") as HTMLSelectElement;
    if (select) {
      select.value = initialTag;
    }
    applyExploreFilters();
  }
</script>
