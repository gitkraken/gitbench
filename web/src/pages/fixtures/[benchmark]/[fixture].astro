---
import Layout from "@/components/Layout.astro";
import PromptBlock from "@/components/fixtures/PromptBlock.astro";
import ExpectedBlock from "@/components/fixtures/ExpectedBlock.astro";
import ModelOutputCard from "@/components/fixtures/ModelOutputCard.astro";
import { FixtureCampaignDetail } from "@/components/FixtureCampaignDetail";
import { loadDataSync } from "@/lib/data";
import type { GitBenchData } from "@/lib/types";
import { Badge } from "@/components/ui/badge";

export function getStaticPaths() {
  const data = loadDataSync();
  return Object.keys(data.fixture_index).map((key) => {
    const [benchmark, fixture] = key.split("/");
    return {
      params: { benchmark, fixture },
      props: { benchmark, fixtureId: fixture, data },
    };
  });
}

const { benchmark, fixtureId, data } = Astro.props as {
  benchmark: string;
  fixtureId: string;
  data: GitBenchData;
};
const fi = data.fixture_index[`${benchmark}/${fixtureId}`];
if (!fi) {
  return new Response("Fixture not found", { status: 404 });
}
const setupCommands = fi.setup ?? [];

// Collect all model outputs for this fixture
const modelOutputs: {
  model: string;
  outputMode: string;
  passed: boolean;
  similarity: number;
  output: string;
  error: string | null;
  inputTokens: number | null;
  outputTokens: number | null;
  reasoningTokens: number | null;
  reasoningLevel: string | null;
  parsedPayload: string | null;
  rawStructuredOutput: string | null;
  structuredError: string | null;
}[] = [];
for (const m of data.models) {
  const results = data.fixtures[m.name]?.[fi.benchmark] || [];
  const fr = results.find((r) => r.fixture_id === fixtureId);
  if (fr) {
    modelOutputs.push({
      model: m.name,
      outputMode: (fr as any).output_mode || "text",
      passed: fr.passed,
      similarity: Math.round(fr.similarity * 1000) / 10,
      output: fr.model_output,
      error: fr.error,
      inputTokens: fr.input_tokens,
      outputTokens: fr.output_tokens,
      reasoningTokens: fr.reasoning_tokens,
      reasoningLevel: fr.reasoning_level,
      parsedPayload: typeof (fr as any).parsed_payload === "string"
        ? (fr as any).parsed_payload
        : null,
      rawStructuredOutput: typeof (fr as any).raw_structured_output === "string"
        ? (fr as any).raw_structured_output
        : null,
      structuredError: typeof (fr as any).structured_error === "string"
        ? (fr as any).structured_error
        : null,
    });
  }
}

// Sort by similarity descending
modelOutputs.sort((a, b) => b.similarity - a.similarity);
const fixtureDescription =
  fi.purpose ||
  fi.description ||
  `GitBench fixture ${fixtureId} from the ${fi.benchmark} benchmark.`;
const fixtureMetaDescription = `${fixtureDescription} See the prompt, expected answer, setup commands, and model outputs for ${fi.benchmark}/${fixtureId}.`;
---

<Layout
  title={`${fixtureId} — ${fi.benchmark}`}
  description={fixtureMetaDescription}
  image="/og/fixture-detail.png"
>
  <div class="mb-6">
    <a
      href={`/benchmarks/${fi.benchmark}`}
      class="font-mono text-[0.68rem] text-accent no-underline"
    >
      ← {fi.benchmark}
    </a>
  </div>

  <div class="card mb-8">
    <div class="flex justify-between items-start flex-wrap gap-4">
      <div>
        <div class="text-xl font-extrabold tracking-tight mb-1">
          {fi.description ? fi.description : fi.id}
        </div>
        {
          fi.purpose && (
            <div class="font-display text-sm text-(--color-text-dim) leading-relaxed mb-3 max-w-[700px]">
              {fi.purpose}
            </div>
          )
        }
      </div>
      <div class="flex gap-2 flex-wrap items-center">
        {
          fi.difficulty && (
            <Badge variant="secondary" className="font-mono text-[0.7rem]">
              {fi.difficulty}
            </Badge>
          )
        }
        {
          fi.tags.map((t) => (
            <a
              href={`/explore?tag=${encodeURIComponent(t)}`}
              class="no-underline"
            >
              <Badge
                variant="secondary"
                className="font-mono text-[0.65rem] cursor-pointer"
              >
                {t}
              </Badge>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  {
    setupCommands.length > 0 && (
      <section class="card mb-8">
        <div class="section-label">
          <span>Baseline Repository</span>
        </div>
        <p class="text-sm text-(--color-text-mid) leading-relaxed max-w-3xl mb-4">
          These commands set up the repo before the model sees the prompt. They
          define the starting file structure, staged changes, and Git history.
        </p>
        <ol class="m-0 p-0 list-none flex flex-col gap-2">
          {setupCommands.map((command, index) => (
            <li class="grid grid-cols-[2.5rem_1fr] gap-3 items-start">
              <span class="font-mono text-[0.7rem] text-(--color-text-dim) pt-2 text-right">
                {String(index + 1).padStart(2, "0")}
              </span>
              <code class="block font-mono text-[0.78rem] leading-relaxed text-(--color-text) bg-(--color-surface) border border-border rounded-md px-3 py-2 overflow-x-auto">
                {command}
              </code>
            </li>
          ))}
        </ol>
      </section>
    )
  }

  <PromptBlock text={fi.prompt} />
  <ExpectedBlock text={fi.expected} />

  <section class="mt-8">
    <div class="section-label">
      <span>Raw Attempt Evidence</span>
    </div>
    <div class="card p-5">
      <FixtureCampaignDetail
        client:load
        benchmark={benchmark}
        fixture={fixtureId}
      />
    </div>
  </section>

  <section class="mt-8">
    <div class="section-label">
      <span>Model Outputs ({modelOutputs.length})</span>
    </div>
    <div class="flex flex-col gap-4">
      {
        modelOutputs.map((mo) => (
          <ModelOutputCard
            modelName={mo.model}
            outputMode={mo.outputMode}
            passed={mo.passed}
            similarity={mo.similarity}
            output={mo.output}
            error={mo.error}
            inputTokens={mo.inputTokens}
            outputTokens={mo.outputTokens}
            reasoningTokens={mo.reasoningTokens}
            reasoningLevel={mo.reasoningLevel}
            parsedPayload={mo.parsedPayload}
            rawStructuredOutput={mo.rawStructuredOutput}
            structuredError={mo.structuredError}
          />
        ))
      }
    </div>
  </section>
</Layout>
