---
import Layout from '@/components/Layout.astro';
import { loadDataSync } from '@/lib/data';
import { modelLevelPath } from '@/lib/routes';
import type { BaseModelGroup } from '@/lib/types';
import { Badge } from '@/components/ui/badge';
import ProviderIcon from '@/components/ProviderIcon.tsx';
import { REASONING_LEVEL_ORDER } from '@/lib/sort-orders';

const data = loadDataSync();

// Group base models by provider so each provider gets one card
const providers = new Map<string, BaseModelGroup[]>();
for (const g of data.base_model_groups) {
  if (!providers.has(g.provider)) providers.set(g.provider, []);
  providers.get(g.provider)!.push(g);
}

const LEVEL_ORDER = REASONING_LEVEL_ORDER;
---

<Layout
  title="Models"
  description="Browse GitBench model results by provider, base model, reasoning level, and output mode."
  image="/og/models.png"
>
  <section class="mb-8">
    <p class="text-sm text-(--color-text-mid) leading-relaxed max-w-3xl mb-2">
      Three levels: <strong class="text-(--color-text)">Provider</strong> → <strong class="text-(--color-text)">Base Model</strong> → <strong class="text-(--color-text)">Reasoning Level</strong>.
      Each base model can have multiple reasoning levels. Higher levels are usually more accurate but slower and costlier.
      Click any card to drill into fixture-by-fixture results.
    </p>
  </section>

  {[...providers.entries()].map(([provider, groups]) => {
    const providerName = provider.charAt(0).toUpperCase() + provider.slice(1);

    return (
      <section class="mb-6">
        <!-- Provider header -->
        <div class="flex items-center gap-2 mb-4">
          <ProviderIcon provider={provider} size={22} client:load />
          <h2 class="text-lg font-bold text-(--color-text)">{providerName}</h2>
        </div>

        <!-- One card per provider -->
        <div class="card p-5 flex flex-col gap-4">
          {groups.map(group => (
            <div>
              <h3 class="text-base font-semibold text-(--color-text) mb-3">{group.baseModel}</h3>

              <div class="text-[0.65rem] font-mono text-(--color-text-dim) mb-2">Text Output</div>
              <div class="grid grid-cols-[repeat(auto-fill,minmax(160px,1fr))] gap-3">
                {group.levels.filter(l => !l.modelName.endsWith('__json_schema')).sort((a, b) => (LEVEL_ORDER[a.level || 'none'] ?? 99) - (LEVEL_ORDER[b.level || 'none'] ?? 99)).map(l => {
                  const passRate = Math.round(l.pass_at_k * 1000) / 10;
                  const passColor = l.pass_at_k >= 0.8
                    ? 'bg-pass-bg text-pass border-pass-border'
                    : l.pass_at_k < 0.5
                      ? 'bg-fail-bg text-fail border-(--color-fail-border)'
                      : 'bg-warn-bg text-(--color-warn) border-(--color-warn-border)';
                  const href = modelLevelPath(provider, group.baseModel, l.level || 'default');

                  return (
                    <a href={href} class="no-underline">
                      <div class="bg-neutral-700 rounded-md border border-[#3E3E3E] p-2 transition-colors hover:border-(--color-border-accent) cursor-pointer">
                        <div class="flex items-center justify-between gap-2">
                          <span class="text-xs font-mono text-(--color-text-dim)">{l.level || 'default'}</span>
                          <Badge variant="outline" className={`font-mono text-[0.6rem] px-1.5 min-w-[2.8rem] text-center ${passColor}`}>
                            {passRate}%
                          </Badge>
                        </div>
                      </div>
                    </a>
                  );
                })}
              </div>

              {group.levels.some(l => l.modelName.endsWith('__json_schema')) && (
                <>
                  <div class="text-[0.65rem] font-mono text-(--color-text-dim) mt-3 mb-2">JSON Schema</div>
                  <div class="grid grid-cols-[repeat(auto-fill,minmax(160px,1fr))] gap-3">
                    {group.levels.filter(l => l.modelName.endsWith('__json_schema')).sort((a, b) => (LEVEL_ORDER[(a.level || 'none').replace(/__json_schema$/, '')] ?? 99) - (LEVEL_ORDER[(b.level || 'none').replace(/__json_schema$/, '')] ?? 99)).map(l => {
                      const passRate = Math.round(l.pass_at_k * 1000) / 10;
                      const passColor = l.pass_at_k >= 0.8
                        ? 'bg-pass-bg text-pass border-pass-border'
                        : l.pass_at_k < 0.5
                          ? 'bg-fail-bg text-fail border-(--color-fail-border)'
                          : 'bg-warn-bg text-(--color-warn) border-(--color-warn-border)';
                      const href = modelLevelPath(provider, group.baseModel, l.level || 'default');

                      return (
                        <a href={href} class="no-underline">
                          <div class="bg-neutral-700 rounded-md border border-[#3E3E3E] p-2 transition-colors hover:border-(--color-border-accent) cursor-pointer">
                            <div class="flex items-center justify-between gap-2">
                              <span class="text-xs font-mono text-(--color-text-dim)">{l.level || 'default'}</span>
                              <Badge variant="outline" className={`font-mono text-[0.6rem] px-1.5 min-w-[2.8rem] text-center ${passColor}`}>
                                {passRate}%
                              </Badge>
                            </div>
                          </div>
                        </a>
                      );
                    })}
                  </div>
                </>
              )}
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Layout>
