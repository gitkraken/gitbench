---
import Layout from "@/components/Layout.astro";
import ComparePage from "@/components/ComparePage";
---

<Layout
  title="Compare"
  description="Compare GitBench model performance side by side across fixtures to find wins, failures, and disagreements."
  image="/og/compare.png"
>
  <div class="info-tip">
    <div class="section-label"><span>About</span></div>
    <p class="info-blurb">
      Pick 2+ models to compare side by side. The head-to-head scatter shows
      which fixtures each model aced and the other bombed. Disagreement is
      where you learn.
    </p>
  </div>
  <ComparePage client:load />
</Layout>
